{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "^/robots\\.txt$",
      "dest": "/robots.txt"
    },
    {
      "src": "^/sitemap\\.xml$",
      "dest": "/sitemap.xml"
    },
    {
      "src": "^/preview$",
      "status": 308,
      "headers": {
        "Location": "/preview/"
      }
    },
    {
      "src": "^/preview/$",
      "dest": "/index.html"
    },
    {
      "src": "^/preview/(.*)$",
      "dest": "/$1"
    },
    {
      "src": "^/(?!internal(?:/.*)?$)(?!preview(?:/.*)?$)(?!content(?:/.*)?$)(?!coming-soon\\.html$).*",
      "dest": "/coming-soon.html"
    }
  ]
}
