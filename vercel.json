{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "^/preview/?$",
      "dest": "/index.html"
    },
    {
      "src": "^/preview/(.*)$",
      "dest": "/$1"
    },
    {
      "src": "^/(?!internal(?:/.*)?$)(?!preview(?:/.*)?$)(?!coming-soon\\.html$).*",
      "dest": "/coming-soon.html"
    }
  ]
}
